    {
      "id": "purchase_type_one_time_order_number",
      "type": "conditional",
      "when": {
        "field": "purchase_type",
        "equals": "one_time"
      },
      "effects": [
        {
          "target": "order_or_invoice_number",
          "visible": true,
          "required": true
        }
      ],
      "otherwise": [
        {
          "target": "order_or_invoice_number",
          "visible": false,
          "required": false
        }
      ]
    },
    {
